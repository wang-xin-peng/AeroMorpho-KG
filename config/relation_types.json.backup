[
  {"name": "具有", "description": "实体具备某种属性、能力或特征。例：'变体飞行器-具有-高机动性'"},
  {"name": "优化", "description": "方法对目标性能产生改善效果。例：'后掠角变化-优化-升阻比'"},
  {"name": "导致", "description": "原因与结果之间的因果联系。例：'气动加热-导致-材料性能下降'"},
  {"name": "包含", "description": "整体与部分之间的组成关系。例：'变形系统-包含-作动器'"},
  {"name": "属于", "description": "实例到类别的归属关系。例：'折叠翼设计-属于-变体飞行器'"},
  {"name": "应用于", "description": "技术、方法的应用场景或领域。例：'变后掠翼技术-应用于-战斗机'"},
  {"name": "采用", "description": "飞行器或系统使用的技术、材料或方法。例：'变体飞行器-采用-形状记忆合金'"},
  {"name": "提高", "description": "某因素对性能指标的提升作用。例：'复合材料-提高-载荷能力'"},
  {"name": "降低", "description": "某因素对不良后果或成本的减少作用。例：'翼梢小翼-降低-诱导阻力'"},
  {"name": "影响", "description": "因素对结果的作用关系。例：'飞行高度-影响-气动特性'"},
  {"name": "用于", "description": "部件、系统或技术的功能用途。例：'作动器-用于-驱动机翼变形'"},
  {"name": "依赖于", "description": "技术或系统对基础条件的依赖关系。例：'变形控制-依赖于-传感器反馈'"},
  {"name": "面临", "description": "技术或系统遇到的挑战、问题或困难。例：'变体飞行器设计-面临-结构复杂度高'"},
  {"name": "解决", "description": "方法、技术或设计对问题的应对或解决。例：'自适应控制-解决-参数不确定性'"},
  {"name": "实现", "description": "技术或设计达到的目标或功能。例：'变弯度机翼-实现-最优气动外形'"},
  {"name": "位于", "description": "部件或结构在整体中的位置关系。例：'升降舵-位于-水平尾翼后缘'"},
  {"name": "连接", "description": "部件之间的物理连接或接口关系。例：'变形机翼-连接-机身'"},
  {"name": "产生", "description": "动作或过程导致的结果或效应。例：'后掠角变化-产生-滚转力矩'"},
  {"name": "限制", "description": "因素对性能或能力的约束作用。例：'作动器技术-限制-变形速度'"},
  {"name": "对比", "description": "两种技术、设计或方案之间的比较关系。例：'折叠翼-对比-变后掠翼'"},
  {"name": "支持", "description": "技术、系统或结构对功能的支撑作用。例：'飞控系统-支持-自动变形'"},
  {"name": "增强", "description": "某因素对能力或性能的强化作用。例：'碳纤维复合材料-增强-结构强度'"},
  {"name": "抑制", "description": "对不利现象或效应的控制或减弱。例：'主动振动控制-抑制-结构振动'"},
  {"name": "转换为", "description": "形态、状态或能量的转变。例：'平直翼状态-转换为-大后掠角状态'"},
  {"name": "配合", "description": "多个部件、系统或技术之间的协同工作关系。例：'变形机构-配合-飞控系统'"},
  {"name": "适应", "description": "飞行器或系统对环境或任务的适应能力。例：'变弯度机翼-适应-不同飞行速度'"},
  {"name": "监测", "description": "传感器或系统对状态、参数的监控和测量。例：'光纤传感器-监测-结构变形状态'"},
  {"name": "驱动", "description": "动力源或执行机构对动作的推动。例：'智能材料作动器-驱动-机翼形状变化'"},
  {"name": "传递", "description": "力、信号或能量的传输路径。例：'飞行控制系统-传递-传感器数据'"},
  {"name": "集成", "description": "多个系统或功能的整合。例：'变形机构-集成-传感器网络'"},
  {"name": "验证", "description": "通过实验或仿真对设计、理论或方法的检验。例：'风洞试验-验证-气动优势'"},
  {"name": "提出", "description": "研究者或文献提出的新方法、新理论或新设计。例：'李教授团队-提出-姿态控制方法'"},
  {"name": "基于", "description": "方法、设计或理论的基础或依据。例：'变形控制策略-基于-强化学习算法'"},
  {"name": "不同于", "description": "两种技术、设计或概念之间的差异。例：'变体飞行器-不同于-传统飞行器'"},
  {"name": "发展为", "description": "技术或设计的演进方向。例：'固定翼设计-发展为-可变形机翼'"},
  {"name": "权衡", "description": "设计中的取舍关系。例：'结构重量-权衡-变形能力'"}
]
